<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.edu.matchvagasapp.features.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/login_view">
        <action
            android:id="@+id/action_login_to_cadastro"
            app:destination="@id/cadastroFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/cadastroFragment"
        android:name="com.edu.matchvagasapp.features.cadastro.CadastroFragment"
        android:label="Cadastro"
        tools:layout="@layout/activity_cadastro">
        <action
            android:id="@+id/action_cadastro_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.edu.matchvagasapp.features.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/dashboard_can">
        <action
            android:id="@+id/action_dashboard_to_detalhes"
            app:destination="@id/detalhesVagaFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_dashboard_to_editar_dados"
            app:destination="@id/editarDadosPessoaisFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_dashboard_to_editar_formacao"
            app:destination="@id/editarFormacaoFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_dashboard_to_editar_experiencia"
            app:destination="@id/editarExperienciaFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_dashboard_to_editar_habilidades"
            app:destination="@id/editarHabilidadesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_dashboard_to_cadastro_curriculo"
            app:destination="@id/cadastroCurriculoFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/editarDadosPessoaisFragment"
        android:name="com.edu.matchvagasapp.features.perfil.EditarDadosPessoaisFragment"
        android:label="Dados Pessoais"
        tools:layout="@layout/fragment_editar_dados_pessoais" >
        <action
            android:id="@+id/btn_voltar2"
            app:destination="@id/perfilFragment" />
    </fragment>

    <fragment
        android:id="@+id/editarFormacaoFragment"
        android:name="com.edu.matchvagasapp.features.perfil.EditarFormacaoFragment"
        android:label="Formação Acadêmica"
        tools:layout="@layout/fragment_editar_formacao">
        <action
            android:id="@+id/action_editarFormacaoFragment_to_perfilFragment"
            app:destination="@id/perfilFragment" />
    </fragment>

    <fragment
        android:id="@+id/editarExperienciaFragment"
        android:name="com.edu.matchvagasapp.features.perfil.EditarExperienciaFragment"
        android:label="Experiência Profissional"
        tools:layout="@layout/fragment_editar_experiencia">
        <action
            android:id="@+id/action_editarExperienciaFragment_to_perfilFragment"
            app:destination="@id/perfilFragment" />
    </fragment>

    <fragment
        android:id="@+id/editarHabilidadesFragment"
        android:name="com.edu.matchvagasapp.features.perfil.EditarHabilidadesFragment"
        android:label="Habilidades"
        tools:layout="@layout/fragment_editar_habilidades">
        <action
            android:id="@+id/action_editarHabilidadesFragment_to_perfilFragment"
            app:destination="@id/perfilFragment" />
    </fragment>

    <fragment
        android:id="@+id/cadastroCurriculoFragment"
        android:name="com.edu.matchvagasapp.features.curriculo.CadastroCurriculoFragment"
        android:label="Cadastro de Currículo"
        tools:layout="@layout/fragment_cadastro_curriculo">
        <action
            android:id="@+id/btn_fechar"
            app:destination="@id/perfilFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_cadastroCurriculoFragment_to_perfilFragment2"
            app:destination="@id/perfilFragment" />
    </fragment>

    <fragment
        android:id="@+id/detalhesVagaFragment"
        android:name="com.edu.matchvagasapp.features.vagas.DetalhesVagaFragment"
        android:label="Detalhes da Vaga"
        tools:layout="@layout/detalhes_vagas">
        <argument android:name="vagaTitulo"  app:argType="string"  android:defaultValue="" />
        <argument android:name="vagaEmpresa" app:argType="string"  android:defaultValue="" />
        <argument android:name="vagaInicial" app:argType="string"  android:defaultValue="?" />
        <argument android:name="vagaLocal"   app:argType="string"  android:defaultValue="" />
        <argument android:name="vagaTipo"    app:argType="string"  android:defaultValue="" />
        <argument android:name="vagaSalario" app:argType="string"  android:defaultValue="" />
        <argument android:name="vagaMatch"   app:argType="integer" android:defaultValue="0" />
        <action
            android:id="@+id/action_detalhes_to_confirmar"
            app:destination="@id/confirmarCandidaturaFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/confirmarCandidaturaFragment"
        android:name="com.edu.matchvagasapp.features.candidatura.ConfirmarCandidaturaFragment"
        android:label="Confirmar Candidatura"
        tools:layout="@layout/confirmar_candidatura">
        <argument android:name="vagaTitulo"  app:argType="string"  android:defaultValue="" />
        <argument android:name="vagaEmpresa" app:argType="string"  android:defaultValue="" />
        <argument android:name="vagaInicial" app:argType="string"  android:defaultValue="?" />
        <argument android:name="vagaMatch"   app:argType="integer" android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/perfilFragment"
        android:name="com.edu.matchvagasapp.features.perfil.PerfilFragment"
        android:label="PerfilFragment" />

</navigation>